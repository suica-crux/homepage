---
import { Image } from 'astro:assets';

type Props = {
  title: string;
  description: string;
  href: string;
  img?: string;
};
const { title, description, href, img } = Astro.props;
---

<div class="w-full md:w-1/3 mb-4 px-2">
  <a href={href} class="block">
    <div
      class="/* 基本の見た目 */
  bg-white shadow rounded-lg overflow-hidden
  /* アニメーション設定...らしい */
  ring-2 ring-transparent
  transition-all duration-200 ease-in-out
  /* ホバー時に色を付ける */
  hover:ring-vipelar hover:shadow-lg"
    >
      {
        img ? (
          <Image
            src={img}
            alt={`${title}のサムネイル画像`}
            width={400}
            height={192}
            class="w-full h-48 object-cover"
          />
        ) : (
          <div class="w-full h-48 g-gray-200 flex items-center justify-center text-gray-500">
            No Image
          </div>
        )
      }
      <div class="p-4">
        <h5 class="text-lg font-semibold mb-2">{title}</h5>
        <p class="text-gray-600">{description}</p>
      </div>
    </div>
  </a>
</div>
