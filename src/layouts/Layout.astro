---
import '@fontsource/m-plus-rounded-1c/400.css';
import '@fontsource/m-plus-rounded-1c/700.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Vipelar</title>
  </head>
  <body class="antialiased">
    <div
      class="absolute top-[-10%] left-[-10%] w-125 h-125 rounded-full bg-purple-200/50 blur-[100px] -z-10"
    >
    </div>

    <div
      class="absolute bottom-[-10%] right-[-10%] w-150 h-150 rounded-full bg-blue-100/60 blur-[120px] -z-10"
    >
    </div>
    <Header />
    <div
      class="grid grid-rows-[20px_1fr_20px] items-center justify-items-center min-h-screen p-8 pb-20 pt-20 gap-16 sm:p-20"
    >
      <div class="justify-self-start"></div>
      <main class="flex flex-col gap-8 row-start-2 items-center sm:items-start">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    overflow-x: clip;
  }
</style>

<style is:global>
  :root {
    --font-mplus-rounded: 'M PLUS Rounded 1c', 'sans-serif';
  }

  body {
    font-family: var(--font-mplus-rounded), serif;
  }
</style>
